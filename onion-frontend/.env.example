# Frontend environment variables example
# Copy to .env and update values for your deployment

# Backend API URL
# For local development:
# REACT_APP_API_URL=http://localhost:8000

# For production:
REACT_APP_API_URL=https://your-backend-production-url.com

# Environment
REACT_APP_ENVIRONMENT=production

# Feature flags
REACT_APP_ENABLE_WEATHER=true
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_HISTORY=true

# Optional: Analytics (add if using)
# REACT_APP_GA_ID=your_google_analytics_id
